@model EmployeeProjectAllocationMVC.Models.ProjectAllocation

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>

<h4>ProjectAllocation</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="ProAllocateId" class="control-label"></label>
                <input asp-for="ProAllocateId" class="form-control" />
                <span asp-validation-for="ProAllocateId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="EmpId" class="control-label"></label>
                <select asp-for="EmpId" class ="form-control" asp-items="ViewBag.EmpId"></select>
            </div>
            <div class="form-group">
                <label asp-for="ProId" class="control-label"></label>
                <select asp-for="ProId"
                        class="form-control"
                        asp-items="ViewBag.ProId">
                    <option value="">-- Select Project --</option>
                </select>
                <span asp-validation-for="ProId" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="AllocationDate" class="control-label"></label>
                <input asp-for="AllocationDate" type="date" class="form-control" />
                <span asp-validation-for="AllocationDate" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
